{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "docs/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/docs/(.*)",
      "dest": "docs/$1"
    },
    {
      "src": "/index.html",
      "dest": "docs/index.html"
    },
    {
      "src": "/",
      "dest": "docs/index.html"
    }
  ]
}
